# Copy to `.env` in the worker directory (or export in your shell).
# RabbitMQ queue defaults also live in `src/specvsreality_worker/config/defaults.yaml`.

# --- Process ---
# WORKER_LOG_LEVEL=INFO
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/specvsreality
# REPO_CLONE_ROOT=/repos
# GIT_CLONE_TOKEN=
# GIT_CLONE_USERNAME=x-access-token

# --- RabbitMQ ---
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_VIRTUAL_HOST=/
# RABBITMQ_QUEUE_NAME=messages
# RABBITMQ_USERNAME=guest
# Long-running handlers (init_repo, wind_to_head, spec_scan) need a high negotiated heartbeat on client *and* broker.
# RABBITMQ_HEARTBEAT=1800
# RABBITMQ_RECONNECT_DELAY_SECONDS=5
RABBITMQ_PASSWORD=guest

# --- Pydantic AI models (provider:model). Requires matching API key in the environment. ---
# SPEC_EXTRACTION_MODEL=openai:gpt-4o-mini
# ARTIFACT_CANDIDATE_AGENT_MODEL=openai:gpt-4o-mini
# IMPLEMENTS_AGENT_MODEL=openai:gpt-4o-mini
# OPENAI_API_KEY=

# --- Model token costs (USD per million tokens). YAML defaults apply; override via JSON. ---
# MODEL_TOKEN_COSTS='{"openai:gpt-4o-mini":{"input_per_million":0.15,"output_per_million":0.60}}'

# --- Implements agent limits ---
# IMPLEMENTS_AGENT_BATCH_SIZE=10
# IMPLEMENTS_AGENT_CONCURRENT_BATCHES=10
# IMPLEMENTS_AGENT_TIMEOUT_SECONDS=600
# IMPLEMENTS_AGENT_REQUEST_LIMIT=10
# IMPLEMENTS_AGENT_MAX_ARTIFACT_CHARS=20000

# --- Artifact candidate agent limits ---
# ARTIFACT_CANDIDATE_AGENT_TIMEOUT_SECONDS=600
# ARTIFACT_CANDIDATE_AGENT_REQUEST_LIMIT=30
# ARTIFACT_CANDIDATE_AGENT_TOOL_CALLS_LIMIT=40
# ARTIFACT_CANDIDATE_AGENT_SEARCH_MAX_FILES=60
# ARTIFACT_CANDIDATE_AGENT_SEARCH_MAX_MATCHES=50
# ARTIFACT_CANDIDATE_AGENT_FIND_FILES_MAX=200
# ARTIFACT_CANDIDATE_AGENT_READ_MAX_BYTES=256000
# ARTIFACT_CANDIDATE_AGENT_READ_MAX_LINES=400
# ARTIFACT_CANDIDATE_AGENT_READ_MAX_LINE_SPAN=120

# --- Verbose Pydantic AI: console spans + DEBUG loggers + per-step event logs ---
# PYDANTIC_AI_VERBOSE=1
# LOGFIRE_CONSOLE_VERBOSE=1

# --- Logfire (Pydantic AI tracing) — typical for deployed environments ---
# LOGFIRE_TOKEN=
# LOGFIRE_SERVICE_NAME=specvsreality-worker
# LOGFIRE_ENVIRONMENT=production

# --- Opik (local/self-hosted OTLP). Set LOGFIRE_TOKEN *or* OPIK_URL_OVERRIDE, not both. ---
# OPIK_URL_OVERRIDE=http://host.docker.internal:5173/api
# OPIK_WORKSPACE=default
# OPIK_API_KEY=
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=...
