# Copy to `.env` in the working directory (or export in your shell).
# Queue name and broker defaults live in `src/specvsreality_worker/config/defaults.yaml`.

# Verbose Pydantic AI: console spans + DEBUG loggers + per-step event logs in the worker.
# PYDANTIC_AI_VERBOSE=1
# WORKER_LOG_LEVEL=DEBUG
#
# Logfire (Pydantic AI tracing) — use in deployed environments (no `logfire auth` CLI needed).
# Create a write token: Logfire project → Settings → Write tokens → New write token.
# The token selects which Logfire *project* receives data; service name is separate (UI grouping).
# EU tokens (pylf_v1_eu_...) route to the EU backend automatically.
# On worker start you should see: "Logfire exporting Pydantic AI traces (...)".
# LOGFIRE_TOKEN=
# LOGFIRE_SERVICE_NAME=specvsreality-worker
# LOGFIRE_ENVIRONMENT=production

# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_VIRTUAL_HOST=/
# RABBITMQ_QUEUE_NAME=messages
# RABBITMQ_USERNAME=guest
# Long-running handlers (scan_repo) need a high negotiated heartbeat on client *and* broker.
# Docker compose sets broker heartbeat/consumer_timeout; for local RabbitMQ, raise both to match.
# RABBITMQ_HEARTBEAT=1800
# RABBITMQ_RECONNECT_DELAY_SECONDS=5
RABBITMQ_PASSWORD=

# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/specvsreality
# REPO_CLONE_ROOT=/repos

# Pydantic AI model strings (provider:model). Requires matching API key in the environment.
# IMPLEMENTS_AGENT_MODEL=openai:gpt-4o-mini
# SPEC_EXTRACTION_MODEL=openai:gpt-4o-mini
# OPENAI_API_KEY=
#
# Implements evaluation limits (per requirement, one agent run).
# IMPLEMENTS_AGENT_TIMEOUT_SECONDS=600
# IMPLEMENTS_AGENT_REQUEST_LIMIT=30
# IMPLEMENTS_AGENT_TOOL_CALLS_LIMIT=40
# IMPLEMENTS_AGENT_SEARCH_MAX_FILES=60
# IMPLEMENTS_AGENT_SEARCH_MAX_MATCHES=50
# IMPLEMENTS_AGENT_FIND_FILES_MAX=200
# IMPLEMENTS_AGENT_TOOL_TIMEOUT_SECONDS=90
# IMPLEMENTS_AGENT_READ_MAX_BYTES=256000
# IMPLEMENTS_AGENT_READ_MAX_LINES=400
# IMPLEMENTS_AGENT_READ_MAX_LINE_SPAN=120

# Tracing: set LOGFIRE_TOKEN *or* OPIK_URL_OVERRIDE, not both. With Logfire, leave OPIK_URL_OVERRIDE unset.
#
# Opik: @opik.track + Pydantic AI OTLP use OPIK_URL_OVERRIDE as the REST API base (must end with /api).
# This repo’s Vite dev server defaults to port 5174 so 5173 can stay free for Opik local (`/api`).
# If ``/api/v1/session/redirect/...`` returns 404, that URL is not the Opik backend.
# https://www.comet.com/docs/opik/self-host/local_deployment
#
# Networking (important):
# - Worker on the host (``uv run``): use ``http://localhost:5173/api`` if Opik publishes 5173 on the host.
# - Worker IN Docker: ``localhost`` is the worker container, NOT Opik. Use one of:
#   - Opik on the host with published port: ``OPIK_URL_OVERRIDE=http://host.docker.internal:5173/api``
#     (compose already sets ``extra_hosts`` for Linux; Docker Desktop has this by default.)
#   - Opik in another container on the SAME Docker network: use that service hostname and *internal*
#     port (e.g. ``http://opik:3000/api``), not ``localhost``. Join networks in compose if needed.
# Verify: ``OPIK_URL_OVERRIDE=... uv run opik healthcheck`` from the same environment as the worker.
# OPIK_URL_OVERRIDE=http://host.docker.internal:5173/api
# OPIK_WORKSPACE=default
# OPIK_API_KEY=
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=...  # if your Opik install requires auth on OTLP
