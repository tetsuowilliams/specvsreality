# Local API (copy to `.env` in repo root or `api/` as needed).

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE_NAME=messages

# Optional: JSON array or comma-separated origins
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Postgres (Alembic + future ORM); use postgresql+psycopg for sync tools
# DATABASE_URL=postgresql+psycopg://specvsreality:specvsreality@localhost:5432/specvsreality
