		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"flowbite-svelte": "^1.33.1",
		"flowbite-svelte-icons": "^3.1.0",
		"marked": "^18.0.5"
